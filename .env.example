# Microsoft Teams Incoming Webhook URL
# Get this from: Teams channel > ... > Connectors > Incoming Webhook
TEAMS_WEBHOOK_URL=https://yourorg.webhook.office.com/webhookb2/PASTE-YOUR-URL-HERE

# How long (minutes) before a zero-CPU Excel process is considered stuck (default: 30)
MAX_RUNTIME_MINUTES=30

# How often the watchdog polls in seconds (default: 20)
CHECK_INTERVAL_SECONDS=20

# Folder for the log file and SQLite database (default: C:\ExcelWatchdog)
DATA_DIR=

EMAIL_SERVER=
EMAIL_PORT=
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_RECIPIENT=
EMAIL_SUBJECT_PREFIX=
